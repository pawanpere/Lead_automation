# Copy this file to .env and fill in your keys
# cp .env.example .env

# PlusVibe API (https://app.plusvibe.ai/v2/settings/api-access/)
PLUSVIBE_API_KEY=your_plusvibe_api_key
PLUSVIBE_API_URL=https://api.plusvibe.ai/api/v1

# Store Leads API (https://storeleads.app/api)
STORELEADS_API_KEY=your_storeleads_api_key
STORELEADS_API_URL=https://storeleads.app/json/api/v1/all

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# LLM Configuration (OpenAI-compatible API)
# Works with Ollama, vLLM, Together AI, Groq, OpenRouter, etc.
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3
LLM_MAX_TOKENS=200
LLM_TEMPERATURE=0.7

# Sender Info
SENDER_EMAIL=your_email@example.com
SENDER_NAME=Your Name
